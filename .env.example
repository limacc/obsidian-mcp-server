# ── obsidian-mcp-server environment variables ─────────────────────────────────
# Copy this file to .env (local dev only — NEVER commit .env to git)
# In Railway: set these in Project → Variables tab

# Secret token shared between this server and Relay MD plugin / sync_all.py
# Generate a strong token: python3 -c "import secrets; print(secrets.token_hex(32))"
RELAY_SECRET=your-strong-secret-token-here

# SQLite database path
# Railway with volume:  /data/obsidian.db
# Railway free (no vol): /tmp/obsidian.db  (ephemeral — re-sync on each restart)
# Local dev:            ./obsidian.db
DB_PATH=/data/obsidian.db

# Port (Railway sets this automatically — do not override in Railway dashboard)
PORT=3000
